{
  "files.exclude": {
    "**/.next": true,
    "**/.open-next": true,
    "**/build": true,
    "**/coverage": true,
    "**/node_modules": true,
    "**/out": true
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/.open-next/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/node_modules/**": true,
    "**/out/**": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/.open-next": true,
    "**/build": true,
    "**/coverage": true,
    "**/node_modules": true,
    "**/out": true
  },
  "typescript.tsserver.watchOptions": {
    "excludeDirectories": [
      "**/.next",
      "**/.open-next",
      "**/build",
      "**/coverage",
      "**/node_modules",
      "**/out"
    ]
  }
}
